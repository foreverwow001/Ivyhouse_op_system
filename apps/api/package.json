{
  "name": "@ivyhouse/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "PORT=3000 IVYHOUSE_EXPECT_SUPABASE=1 node dist/main.js",
    "start:dev": "PORT=3000 IVYHOUSE_EXPECT_SUPABASE=1 node --require ts-node/register src/main.ts",
    "smoke:local:supabase": "node scripts/local-runtime-supabase-smoke.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "preflight:migration": "node scripts/migration-preflight.js",
    "drill:migration-replay": "node scripts/migration-replay-drill.js",
    "prisma:seed": "prisma db seed --schema prisma/schema.prisma",
    "test:fixtures": "npm run build && node --test test/intake-parser-fixtures.test.js",
    "test:mapping:fixtures": "npm run build && node --test test/intake-mapping-fixtures.test.js",
    "test:mapping:smoke": "npm run build && node test/intake-mapping-api-smoke.js",
    "test:smoke": "npm run build && node test/intake-api-smoke.js",
    "test:recipe-owner": "npm run build && node --test test/recipe-owner-direct-pack.test.js",
    "test:daily-ops:mainline": "npm run build && node test/daily-ops-mainline-e2e-smoke.js",
    "test:daily-ops:regression": "npm run build && node test/daily-ops-regression-suite.js",
    "test:inventory:metrics": "npm run build && node --test test/inventory-count-metrics.test.js",
    "test:inventory:smoke": "npm run build && node test/inventory-count-api-smoke.js"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}