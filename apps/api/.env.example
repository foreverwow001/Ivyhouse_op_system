# Ivyhouse API local example

# Required: Prisma / NestJS primary database connection.
DATABASE_URL=postgresql://vscode@127.0.0.1:55432/ivyhouse_api_dev?schema=public

# Optional but recommended for managed providers: direct database connection used by Prisma migrations.
DIRECT_URL=postgresql://vscode@127.0.0.1:55432/ivyhouse_api_dev?schema=public

# Optional: admin database used by selected regression or database management scripts.
# For managed providers like Supabase, do not point this at production unless you have a separately approved admin-capable scratch server.
ADMIN_DATABASE_URL=postgresql://vscode@127.0.0.1:55432/postgres

# Optional: API listen port. Local smoke tests override this value per script.
PORT=3000
