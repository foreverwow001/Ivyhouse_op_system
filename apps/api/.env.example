# Ivyhouse API local example

# Required: existing Supabase Prisma / NestJS primary database connection.
# Local start scripts pin API to 127.0.0.1:3000 and runtime 會以 apps/api/src/main.ts 的 loader 讀取這份 .env。
DATABASE_URL=postgresql://<db-user>:<db-password>@<project-ref>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public

# Optional but recommended for managed providers: direct database connection used by Prisma migrations.
DIRECT_URL=postgresql://<db-user>:<db-password>@db.<project-ref>.supabase.com:5432/postgres?schema=public

# Optional: admin database used by selected regression or database management scripts.
# Keep this empty unless you have an explicitly approved admin-capable scratch target.
ADMIN_DATABASE_URL=

# Optional: local startup scripts force 3000; keep this aligned if you run custom commands manually.
PORT=3000
